{
  "name": "@rzv/make-brand",
  "version": "0.2.1",
  "description": "Minimal brand toolkit for Zod",
  "keywords": [
    "brand",
    "branded",
    "nominal",
    "runtime",
    "type-safety",
    "types",
    "typescript",
    "validation",
    "zod"
  ],
  "homepage": "https://github.com/ruimage/make-brand#readme",
  "bugs": {
    "url": "https://github.com/ruimage/make-brand/issues"
  },
  "license": "MIT",
  "author": "Valkouski Anton <valkouski.anton@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruimage/make-brand.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "prepublishOnly": "vp run build",
    "release:patch": "bumpp patch",
    "release:minor": "bumpp minor",
    "release:major": "bumpp major",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "11.0.1",
    "husky": "9.1.7",
    "typescript": "5.9.3",
    "vite-plus": "0.1.17"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
  },
  "packageManager": "npm@11.12.0"
}
